# Backend environment variables — copy to .env and fill in your values
SECRET_KEY=your-very-secret-key-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=your-backend.onrender.com,your-backend.railway.app
DATABASE_URL=postgresql://user:password@host:5432/dbname
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-frontend.netlify.app
